name: Build and deploy Node.js app to Azure Web App - ModernE-Wa

on:
  push:
    branches: [ main ]
  workflow_dispatch:

jobs:
  build:
    runs-on: ubuntu-latest
    permissions:
      contents: read

    steps:
      - name: Checkout repo
        uses: actions/checkout@v4

      - name: Setup Node
        uses: actions/setup-node@v4
        with:
          node-version: '22.x'
          cache: 'npm'

      - name: Clean install dependencies
        run: |
          rm -rf node_modules
          npm cache clean --force
          npm install --include=dev

          # Rollup native optional deps guard (npm bug workaround)
          node -e "require('@rollup/rollup-linux-x64-gnu')" || npm i --no-save @rollup/rollup-linux-x64-gnu

      - name: Build workspaces
        run: |
          npm run prisma:generate -w @efm/api
          npm run build -w @efm/shared
          npm run build -w @efm/api
          npm run build -w @efm/web

      - name: Verify builds
        run: |
          test -f out/apps/api/server.js
          test -f out/apps/web/index.html

      - name: Upload deployment artifact
        uses: actions/upload-artifact@v4
        with:
          name: node-app
          include-hidden-files: true
          path: |
            package.json
            package-lock.json
            node_modules/**
            apps/api/**
            packages/shared/**
            out/**
            !.git/**

  deploy:
    runs-on: ubuntu-latest
    needs: build
    permissions:
      id-token: write
      contents: read

    steps:
      - name: Download artifact
        uses: actions/download-artifact@v4
        with:
          name: node-app

      - name: Login to Azure
        uses: azure/login@v2
        with:
          client-id: ${{ secrets.AZUREAPPSERVICE_CLIENTID_D8C1D4B170064F9687AF10B020613A74 }}
          tenant-id: ${{ secrets.AZUREAPPSERVICE_TENANTID_9DE26AB418AA4F73962F71F9B04BB37C }}
          subscription-id: ${{ secrets.AZUREAPPSERVICE_SUBSCRIPTIONID_6611870FDC0C4766967CD571449F87C6 }}

      - name: Configure App Service
        run: |
          RG=$(az resource list --name ModernE-Wa --resource-type Microsoft.Web/sites --query "[0].resourceGroup" -o tsv)
          echo "Resource group: $RG"

          az webapp config appsettings set \
            --name ModernE-Wa \
            --resource-group "$RG" \
            --settings \
            SCM_DO_BUILD_DURING_DEPLOYMENT=false \
            ENABLE_ORYX_BUILD=false \
            WEBSITE_WARMUP_PATH=/api/health \
            WEBSITES_CONTAINER_START_TIME_LIMIT=1800

          az webapp config set \
            --name ModernE-Wa \
            --resource-group "$RG" \
            --startup-file "node out/apps/api/server.js"

      - name: Deploy to Azure Web App
        uses: azure/webapps-deploy@v3
        with:
          app-name: ModernE-Wa
          slot-name: Production
          package: .

      - name: Post-deploy health check
        run: |
          curl -f https://app.modernendpoint.tech/api/health