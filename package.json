{
  "name": "enrollment-flow-monitor-monorepo",
  "private": true,
  "version": "1.0.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev -w @efm/api\" \"npm run dev -w @efm/web\"",
    "build": "npm run build -w @efm/shared && npm run build -w @efm/api && npm run build -w @efm/web",
    "lint": "npm run lint --workspaces",
    "prisma:generate": "npm run prisma:generate -w @efm/api",
    "prisma:migrate": "npm run prisma:migrate -w @efm/api"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "concurrently": "^9.1.2"
  }
}
